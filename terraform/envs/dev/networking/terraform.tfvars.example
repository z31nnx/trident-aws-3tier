region      = "us-east-1"
environment = "dev"
project     = "trident"
owner       = "your_name"
managedby   = "terraform"

vpc_name             = "3-tier"
cidr_block           = "10.0.0.0/16"
enable_dns_support   = true
enable_dns_hostnames = true
subnets = {
  "web-public-a"  = { type = "public", cidr = "10.0.1.0/24", az = "us-east-1a" }
  "web-public-b"  = { type = "public", cidr = "10.0.2.0/24", az = "us-east-1b" }
  "app-private-a" = { type = "private", cidr = "10.0.3.0/24", az = "us-east-1a" }
  "app-private-b" = { type = "private", cidr = "10.0.4.0/24", az = "us-east-1b" }
  "rds-private-a" = { type = "database", cidr = "10.0.5.0/24", az = "us-east-1a" }
  "rds-private-b" = { type = "database", cidr = "10.0.6.0/24", az = "us-east-1b" }
}
