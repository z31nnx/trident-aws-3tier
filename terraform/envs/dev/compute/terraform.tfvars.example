region      = "us-east-1"
environment = "dev"
project     = "trident"
owner       = "your_name"
managedby   = "terraform"

ami_id        = "al2023-ami-2023.*-x86_64"
instance_type = "t3.micro"
device_name   = "/dev/xvda"
root_volume = {
  "main" = {
    volume_size = 20
    encrypted   = true
  }
}
metadata_options = {
  "main" = {
    http_endpoint               = "enabled"
    http_tokens                 = "required"
    http_put_response_hop_limit = 1
    instance_metadata_tags      = "enabled"
  }
}